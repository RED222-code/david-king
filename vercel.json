{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/",         "destination": "/html/index" },
    { "source": "/about",    "destination": "/html/about" },
    { "source": "/projects", "destination": "/html/projects" }
  ],
  "redirects": [
    { "source": "/html/index",    "destination": "/",         "permanent": true },
    { "source": "/html/about",    "destination": "/about",    "permanent": true },
    { "source": "/html/projects", "destination": "/projects", "permanent": true }
  ]
}
